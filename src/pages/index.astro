		color: white;
		border: none;
		font-size: 30px;
		padding: 10px;
		cursor: pointer;
		border-radius: 5px;
		transition: background 0.3s;
	}

	.prev:hover,
	.next:hover {
		background: rgba(0, 0, 0, 0.8);
	}

	.prev {
		left: 15px;
	}

	.next {
		right: 15px;
	}
</style>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		const modal = document.getElementById('lightbox-modal') as HTMLElement;
		const modalImg = document.getElementById('lightbox-img') as HTMLImageElement;
		const closeBtn = document.querySelector('.close') as HTMLElement;
		const prevBtn = document.querySelector('.prev') as HTMLButtonElement;
		const nextBtn = document.querySelector('.next') as HTMLButtonElement;

		let currentImages: HTMLImageElement[] = [];
		let currentIndex = 0;

		const showImage = (index: number) => {
			if (index >= 0 && index < currentImages.length) {
				currentIndex = index;
				modalImg.src = currentImages[index].src;
				modalImg.alt = currentImages[index].alt;
			}
		};

		document.querySelectorAll<HTMLImageElement>('.scenario-images img').forEach(img => {
			img.addEventListener('click', () => {
				const scenarioImages = img.closest('.scenario-images') as HTMLElement;
				currentImages = Array.from(scenarioImages.querySelectorAll<HTMLImageElement>('img'));
				currentIndex = currentImages.indexOf(img);
				modal.style.display = 'block';
				showImage(currentIndex);
			});
		});

		prevBtn.onclick = () => {
			showImage(currentIndex - 1);
		};

		nextBtn.onclick = () => {
			showImage(currentIndex + 1);
		};

		closeBtn.onclick = () => {
			modal.style.display = 'none';
		};

		modal.onclick = (e) => {
			if (e.target === modal) {
				modal.style.display = 'none';
			}
		};
	});
</script>
